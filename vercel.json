{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/login",
      "destination": "/api/admin?action=login"
    },
    {
      "source": "/admin/session",
      "destination": "/api/admin?action=session"
    },
    {
      "source": "/admin/logout",
      "destination": "/api/admin?action=logout"
    },
    {
      "source": "/admin/data",
      "destination": "/api/admin?action=data"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/public/index.html"
    },
    {
      "source": "/app",
      "destination": "/public/app.html"
    },
    {
      "source": "/app.html",
      "destination": "/public/app.html"
    },
    {
      "source": "/404.html",
      "destination": "/public/404.html"
    },
    {
      "source": "/sw.js",
      "destination": "/public/sw.js"
    },
    {
      "source": "/css/:path*",
      "destination": "/public/css/:path*"
    },
    {
      "source": "/js/:path*",
      "destination": "/public/js/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=()"
        }
      ]
    }
  ]
}
