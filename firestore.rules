rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // FUNÇÕES AUXILIARES DE SEGURANÇA
    // ==========================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Recomenda-se no futuro usar custom claims: request.auth.token.admin == true
      return isAuthenticated() && request.auth.token.email == "admin@caronasaqui.internal";
    }

    function validProfileTags(tags) {
      return tags is list
        && tags.size() <= 8
        && tags.hasOnly([
          "rock",
          "funk",
          "sertanejo",
          "eletronica",
          "falante",
          "quieto",
          "pontual",
          "sem-fumaca"
        ]);
    }

    // ==========================================
    // USUÁRIOS
    // ==========================================
    match /usuarios/{userId} {
      // Qualquer usuário autenticado pode ler os perfis básicos
      allow read: if isAuthenticated();
      
      // Apenas o próprio usuário pode criar seu registro com validação rígida de dados
      allow create: if isOwner(userId)
        && request.resource.data.nome is string
        && request.resource.data.nome.size() >= 3
        && request.resource.data.matriculaHash is string
        && request.resource.data.matriculaHash.matches('^[a-f0-9]{64}$')
        && request.resource.data.matriculaLast4 is string
        && request.resource.data.matriculaLast4.matches('^[0-9]{4}$')
        && request.resource.data.faculdadeId in ["dom-bosco-resende", "uerj-resende"]
        && (!("tags" in request.resource.data) || validProfileTags(request.resource.data.tags));
      
      // Apenas o dono pode atualizar, sendo impedido de alterar dados sensíveis
      allow update: if isOwner(userId)
        && (!("nome" in request.resource.data) || request.resource.data.nome.size() >= 3)
        && (!("email" in request.resource.data) || request.resource.data.email is string)
        && (!("celular" in request.resource.data) || request.resource.data.celular is string)
        && (!("curso" in request.resource.data) || request.resource.data.curso is string)
        && (!("foto" in request.resource.data) || request.resource.data.foto is string)
        && (!("tags" in request.resource.data) || validProfileTags(request.resource.data.tags))
        // Proteção: matriculaHash e faculdadeId não podem ser modificados após criados
        && (!("matriculaHash" in request.resource.data) || request.resource.data.matriculaHash == resource.data.matriculaHash)
        && (!("faculdadeId" in request.resource.data) || request.resource.data.faculdadeId == resource.data.faculdadeId);
        
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ==========================================
    // CARONAS
    // ==========================================
    match /caronas/{caronaId} {
      // Usuários autenticados podem buscar caronas
      allow read: if isAuthenticated();
      
      // Validação do motorista na criação
      allow create: if isAuthenticated()
        && request.resource.data.motoristaId == request.auth.uid
        && request.resource.data.partidaLivre is string
        && request.resource.data.partidaLivre.matches('^[^<>]{3,140}$')
        && request.resource.data.faculdadeId in ["dom-bosco-resende", "uerj-resende"]
        && request.resource.data.faculdadeLat is number
        && request.resource.data.faculdadeLng is number;
        
      // Apenas o motorista que criou pode editar sua própria carona
      allow update: if isOwner(resource.data.motoristaId)
        && request.resource.data.motoristaId == resource.data.motoristaId // Impede transferência de propriedade
        && (!("partidaLivre" in request.resource.data)
          || (request.resource.data.partidaLivre is string
            && request.resource.data.partidaLivre.matches('^[^<>]{3,140}$')))
        && (!("faculdadeId" in request.resource.data)
          || request.resource.data.faculdadeId == resource.data.faculdadeId); // Impede mudança de faculdade
          
      allow delete: if isOwner(resource.data.motoristaId) || isAdmin();

      // ==========================================
      // LOCALIZAÇÕES DA CARONA (Subcoleção)
      // ==========================================
      match /localizacoes/{passageiroId} {
        allow read: if isAuthenticated();
        // Apenas o passageiro específico pode atualizar sua localização
        allow write: if isOwner(passageiroId);
      }
    }

    // ==========================================
    // SOLICITAÇÕES
    // ==========================================
    match /solicitacoes/{solId} {
      // Apenas os envolvidos (motorista ou passageiro) podem ver a solicitação
      allow read: if isAuthenticated()
        && (request.auth.uid == resource.data.passageiroId || request.auth.uid == resource.data.motoristaId)
        || isAdmin();
        
      // O passageiro cria a solicitação
      allow create: if isAuthenticated()
        && request.resource.data.passageiroId == request.auth.uid
        && request.resource.data.status in ["pending", "pendente"];
        
      // REGRA CRÍTICA CORRIGIDA: Passageiro não pode se auto-aprovar
      allow update: if isAuthenticated()
        // Impede alterar os envolvidos
        && request.resource.data.passageiroId == resource.data.passageiroId
        && request.resource.data.motoristaId == resource.data.motoristaId
        && (
          // Se for o motorista, ele pode aprovar ou recusar
          (request.auth.uid == resource.data.motoristaId && request.resource.data.status in ["approved", "aceita", "rejected", "recusada", "pending", "pendente"])
          ||
          // Se for o passageiro, ele só pode cancelar a solicitação
          (request.auth.uid == resource.data.passageiroId && request.resource.data.status in ["cancelled", "cancelada"])
        );
        
      allow delete: if isOwner(resource.data.passageiroId) || isAdmin();
    }

    // ==========================================
    // CHATS
    // ==========================================
    match /chats/{chatId} {
      // REGRA CRÍTICA CORRIGIDA: Apenas participantes do chat podem lê-lo
      allow read: if isAuthenticated() 
        && request.auth.uid in resource.data.participantes;
        
      // O criador do chat deve estar na lista de participantes
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantes;
        
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantes;

      // ==========================================
      // MENSAGENS (Subcoleção de Chats)
      // ==========================================
      match /mensagens/{msgId} {
        // Apenas participantes da conversa podem ler
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;
          
        // REGRA CRÍTICA CORRIGIDA: Permissão separada (create ao invés de write)
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes
          && request.resource.data.senderId == request.auth.uid; // Previne falsificação de remetente
          
        // Apenas o próprio autor pode editar/deletar suas mensagens
        allow update, delete: if isOwner(resource.data.senderId);
      }
    }

    // ==========================================
    // MENSAGENS DIRETAS (Estrutura legada/alternativa)
    // ==========================================
    match /mensagens/{conversaId} {
      // Mesma proteção aplicada à coleção de chats
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participantes;
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participantes;
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participantes;

      match /msgs/{msgId} {
        allow read: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/mensagens/$(conversaId)).data.participantes;
          
        allow create: if isAuthenticated()
          && request.auth.uid in get(/databases/$(database)/documents/mensagens/$(conversaId)).data.participantes
          && (request.resource.data.senderId == request.auth.uid || request.resource.data.remetenteId == request.auth.uid);
          
        allow update, delete: if isAuthenticated() 
          && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.remetenteId);
      }
    }

    // ==========================================
    // DEFAULT DENY (Fechamento)
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
